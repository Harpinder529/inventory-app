{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth",          "dest": "/api/auth.js" },
    { "src": "/api/send-asc-mail", "dest": "/api/send-asc-mail.js" },
    { "src": "/login",             "dest": "/public/login.html" },
    { "src": "/asc-mail",          "dest": "/public/asc-mail.html" },
    { "src": "/weekly-report",     "dest": "/public/weekly-report.html" },
    { "src": "/",                  "dest": "/public/index.html" },
    { "src": "/(.*)",              "dest": "/public/$1" }
  ]
}